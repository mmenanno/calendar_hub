<% failing_sources = CalendarSource.failing.includes(:latest_sync_attempt).order(:name) %>
<% if failing_sources.any? %>
  <div id="sync-failure-alerts" class="mx-auto max-w-6xl px-6 pt-4 space-y-2" data-controller="dismissible">
    <% failing_sources.each do |source| %>
      <% failure_count = source.consecutive_sync_failures.to_i %>
      <% latest = source.latest_sync_attempt %>
      <% banner_class = failure_count >= 3 ? "border-rose-800 bg-rose-950/40 text-rose-200" : "border-yellow-700 bg-yellow-950/40 text-yellow-200" %>
      <div class="rounded-lg border px-4 py-3 text-sm flex items-start justify-between gap-3 <%= banner_class %>"
           data-dismissible-target="banner"
           data-source-id="<%= source.id %>"
           data-failure-count="<%= failure_count %>">
        <div class="space-y-1">
          <div>
            <strong><%= source.name %></strong>
            <%= t("ui.sources.health.alert_message", count: failure_count) %>
            <%= link_to t("common.actions.view"), calendar_source_path(source), class: "underline font-medium hover:no-underline ml-1" %>
          </div>
          <% if latest %>
            <% if latest.message.present? %>
              <p class="text-xs opacity-80 font-mono truncate max-w-2xl" title="<%= latest.message %>"><%= latest.message.truncate(200) %></p>
            <% end %>
            <% event_errors = latest.sync_event_results.failures.limit(3) %>
            <% if event_errors.any? %>
              <div class="text-xs opacity-70 space-y-0.5">
                <% event_errors.each do |result| %>
                  <p class="font-mono truncate max-w-2xl" title="<%= result.error_message %>"><%= result.external_id.to_s.truncate(30) %>: <%= result.error_message.to_s.truncate(150) %></p>
                <% end %>
                <% remaining = latest.errors_count.to_i - event_errors.size %>
                <% if remaining > 0 %>
                  <p class="italic">…and <%= remaining %> more</p>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
        <button type="button" class="cursor-pointer shrink-0 text-current opacity-60 hover:opacity-100" data-action="click->dismissible#dismiss" aria-label="<%= t("common.actions.close") %>">
          &times;
        </button>
      </div>
    <% end %>
  </div>
<% end %>
